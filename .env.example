# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Amazon Bedrock
# Local: set AWS_PROFILE to a named profile in ~/.aws/credentials
# EC2:   leave AWS_PROFILE unset — boto3 uses the instance IAM role automatically
AWS_PROFILE=
# Leave BEDROCK_REGION unset on EC2 — boto3 auto-detects the instance region
# Set explicitly for local use (e.g. us-east-1, us-west-2)
BEDROCK_REGION=
